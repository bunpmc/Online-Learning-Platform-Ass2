@page "/Course/Browse"
@model OnlineLearningPlatformAss2.RazorWebApp.Pages.Course.BrowseModel
@{
    ViewData["Title"] = "Browse Courses";
    var displayCount = Model.Courses?.Count() ?? Model.TotalCourses;
}

@section Styles {
    <link rel="stylesheet" href="~/css/course-browse.css" asp-append-version="true" />
}

<div class="browse-page">
    <!-- Hero Section -->
    <section class="browse-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="hero-title">Discover Your Next Course</h1>
                    <p class="hero-subtitle">Explore our collection of courses to advance your skills</p>
                </div>
                <div class="col-lg-4">
                    <div class="search-stats">
                        <div class="stat">
                            <span class="number">@displayCount</span>
                            <span class="label">COURSES AVAILABLE</span>
                        </div>
                        <div class="stat">
                            <span class="number">@Model.Categories.Count()</span>
                            <span class="label">CATEGORIES</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Filters & Search -->
    <section class="browse-filters">
        <div class="container">
            <form method="get" id="filterForm">
                <div class="filter-bar">
                    <div class="row align-items-center g-3">
                        <!-- Search Box -->
                        <div class="col-lg-4 col-md-6">
                            <div class="search-box">
                                <i class="bi bi-search"></i>
                                <input type="text" 
                                       name="SearchTerm"
                                       id="searchInput" 
                                       placeholder="Search courses..." 
                                       value="@Model.SearchTerm"
                                       autocomplete="off">
                                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                {
                                    <button type="button" class="search-clear" id="searchClear">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Category Filter -->
                        <div class="col-lg-3 col-md-6">
                            <div class="filter-dropdown">
                                <select name="CategoryId" id="categoryFilter" class="form-select">
                                    <option value="">All Categories</option>
                                    @foreach (var category in Model.Categories)
                                    {
                                        <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">
                                            @category.Name
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- Sort Options -->
                        <div class="col-lg-3 col-md-6">
                            <div class="filter-dropdown">
                                <select name="SortBy" id="sortFilter" class="form-select">
                                    <option value="newest" selected="@(Model.SortBy == "newest")">Newest First</option>
                                    <option value="title" selected="@(Model.SortBy == "title")">Title A-Z</option>
                                    <option value="price_low" selected="@(Model.SortBy == "price_low")">Price: Low to High</option>
                                    <option value="price_high" selected="@(Model.SortBy == "price_high")">Price: High to Low</option>
                                    <option value="rating" selected="@(Model.SortBy == "rating")">Highest Rated</option>
                                </select>
                            </div>
                        </div>

                        <!-- Results Count -->
                        <div class="col-lg-2 col-md-6 text-end">
                            <div class="results-count">
                                <strong>@displayCount</strong> courses
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Active Filters -->
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.CategoryId.HasValue)
                {
                    <div class="active-filters">
                        <span class="filter-label">Active filters:</span>
                        <div class="filter-tags">
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <span class="filter-tag">
                                    Search: "@Model.SearchTerm"
                                    <a href="@Url.Page("/Course/Browse", new { CategoryId = Model.CategoryId, SortBy = Model.SortBy })" class="filter-remove">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </span>
                            }
                            @if (Model.CategoryId.HasValue)
                            {
                                <span class="filter-tag">
                                    Category: @Model.SelectedCategoryName
                                    <a href="@Url.Page("/Course/Browse", new { SearchTerm = Model.SearchTerm, SortBy = Model.SortBy })" class="filter-remove">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </span>
                            }
                        </div>
                        <a href="@Url.Page("/Course/Browse")" class="clear-all-filters">
                            Clear all
                        </a>
                    </div>
                }
            </form>
        </div>
    </section>

    <!-- Course Grid -->
    <section class="browse-content">
        <div class="container" id="courseGridContainer">
            @await Html.PartialAsync("_CourseGrid", new ViewDataDictionary(ViewData) { 
                { "Courses", Model.Courses }, 
                { "TotalCourses", Model.TotalCourses },
                { "SearchTerm", Model.SearchTerm },
                { "SelectedCategoryName", Model.SelectedCategoryName }
            })
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('courseGridContainer');
            const searchInput = document.getElementById('searchInput');
            const categoryFilter = document.getElementById('categoryFilter');
            const sortFilter = document.getElementById('sortFilter');
            const searchClear = document.getElementById('searchClear');
            
            let searchTimeout;
            
            function updateCounters() {
                const count = document.querySelectorAll('.course-card').length;
                const heroNum = document.querySelector('.browse-hero .number');
                const filterNum = document.querySelector('.results-count strong');
                const filterBarCountDisplay = document.querySelector('.results-count'); // The whole "X courses" div
                
                if (heroNum) heroNum.textContent = count;
                if (filterNum) filterNum.textContent = count;
            }

            async function updateGrid() {
                container.style.opacity = '0.5';
                container.style.pointerEvents = 'none';

                const params = new URLSearchParams({
                    handler: 'CourseGrid',
                    SearchTerm: searchInput.value.trim(),
                    CategoryId: categoryFilter.value,
                    SortBy: sortFilter.value,
                    t: Date.now() // Cache buster
                });

                try {
                    const response = await fetch(`?${params.toString()}`);
                    if (response.ok) {
                        const html = await response.text();
                        container.innerHTML = html;
                        
                        const newUrl = `?${new URLSearchParams({
                            SearchTerm: searchInput.value,
                            CategoryId: categoryFilter.value,
                            SortBy: sortFilter.value
                        }).toString()}`;
                        window.history.pushState({ path: newUrl }, '', newUrl);
                        
                        updateCounters();
                    }
                } catch (error) {
                    console.error('Error filtering courses:', error);
                } finally {
                    container.style.opacity = '1';
                    container.style.pointerEvents = 'auto';
                }
            }
            
            searchInput?.addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => updateGrid(), 500);
                if (searchClear) searchClear.style.display = searchInput.value ? 'block' : 'none';
            });
            
            searchClear?.addEventListener('click', () => {
                searchInput.value = '';
                searchClear.style.display = 'none';
                updateGrid();
            });
            
            categoryFilter?.addEventListener('change', () => updateGrid());
            sortFilter?.addEventListener('change', () => updateGrid());

            window.addEventListener('popstate', () => location.reload());

            // ===== SignalR Real-time Updates =====
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/course")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveCourseAdded", (course) => {
                const status = course.status || course.Status;
                
                // If it is published right away, add it to the grid
                if (status === "Published") {
                    const price = course.price ?? course.Price ?? 0;
                    const priceDisplay = price === 0 ? 'Miễn phí' : `${price.toLocaleString()}₫`;
                    showToast(`Khóa học mới: ${course.title || course.Title}`, 'success');
                    appendCourseCard(course);
                    updateCounters();
                }
            });

            connection.on("ReceiveCourseUpdated", (course) => {
                const status = course.status || course.Status;
                const id = course.id || course.Id;
                const title = course.title || course.Title;

                const card = document.querySelector(`[data-course-id="${id}"]`);

                if (status !== "Published") {
                    // Remove nếu tồn tại
                    if (card) {
                        card.remove();
                        updateCounters();
                        showToast(`Khóa học "${title}" đã được gỡ khỏi danh sách.`, 'warning');
                    }
                    return;
                }

                // ===== status === Published =====

                if (card) {
                    // Update card
                    const titleEl = card.querySelector('.course-title a');
                    if (titleEl) titleEl.textContent = title;

                    const descEl = card.querySelector('.course-description');
                    if (descEl) descEl.textContent = course.description || course.Description || '';

                    const instructorEl = card.querySelector('.instructor');
                    if (instructorEl) instructorEl.innerHTML =
                        `<i class="bi bi-person"></i> ${course.instructorName || course.InstructorName || ''}`;

                    const categoryEl = card.querySelector('.course-badge .badge');
                    if (categoryEl) categoryEl.textContent =
                        course.categoryName || course.CategoryName || '';

                    const priceEl = card.querySelector('.course-price .price');
                    const price = course.price ?? course.Price ?? 0;
                    if (priceEl) priceEl.textContent =
                        price === 0 ? 'Miễn phí' : `${price.toLocaleString()}₫`;

                    showToast(`Khóa học "${title}" đã được cập nhật.`, 'info');
                } else {
                    // Unsuspend hoặc create mới
                    appendCourseCard(course);
                    updateCounters();
                    showToast(`Khóa học "${title}" đã được xuất bản.`, 'success');
                }
            });

            connection.on("ReceiveCourseDeleted", (courseId) => {
                const cards = document.querySelectorAll(`[data-course-id="${courseId}"]`);
                cards.forEach(card => {
                    card.remove();
                });
                updateCounters();
                showToast("Một khóa học đã bị gỡ bỏ.", 'info');
            });

            connection.start()
                .then(() => console.log("SignalR connected."))
                .catch(err => console.error("SignalR Connection Error: ", err));

            window.appendCourseCard = function(course) {
                const container = document.getElementById('courseGridContainer');
                const price = course.price ?? course.Price ?? 0;
                const priceDisplay = price === 0 ? 'Miễn phí' : `${price.toLocaleString()}₫`;
                const id = course.id || course.Id;
                const title = course.title || course.Title;
                const imageUrl = course.imageUrl || course.ImageUrl;
                const categoryName = course.categoryName || course.CategoryName || '';
                const instructorName = course.instructorName || course.InstructorName || '';
                const description = course.description || course.Description || '';
                const studentCount = course.studentCount || course.StudentCount || 0;
                
                let gridRow = container.querySelector('.course-grid .row');
                if (!gridRow) {
                    container.innerHTML = `
                        <div class="course-grid">
                            <div class="row g-4"></div>
                        </div>
                    `;
                    gridRow = container.querySelector('.course-grid .row');
                }

                const col = document.createElement('div');
                col.className = 'col-lg-4 col-md-6';
                col.setAttribute('data-course-id', id);
                
                col.innerHTML = `
                    <div class="course-card" data-aos="fade-up">
                        <div class="course-image">
                            ${imageUrl ? `<img src="${imageUrl}" alt="${title}" loading="lazy">` : `<div class="course-placeholder"><i class="bi bi-book"></i></div>`}
                            <div class="course-overlay">
                                <a href="/Course/Details?id=${id}" class="btn-preview">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                            </div>
                            <div class="course-badge">
                                <span class="badge bg-primary">${categoryName}</span>
                            </div>
                        </div>
                        
                        <div class="course-content">
                            <div class="course-meta">
                                <span class="instructor">
                                    <i class="bi bi-person"></i>
                                    ${instructorName}
                                </span>
                                <div class="course-rating">
                                    <div class="star-rating px-1">
                                        <!-- Real rating handled on page reload, showing empty/default for real-time -->
                                        <i class="bi bi-star text-warning"></i>
                                    </div>
                                </div>
                            </div>
                            
                            <h3 class="course-title">
                                <a href="/Course/Details?id=${id}">${title}</a>
                            </h3>
                            
                            <p class="course-description">${description}</p>
                            
                            <div class="course-stats">
                                <div class="stat">
                                    <i class="bi bi-clock"></i>
                                    <span>Self-paced</span>
                                </div>
                                <div class="stat">
                                    <i class="bi bi-people"></i>
                                    <span>${studentCount} students</span>
                                </div>
                                <div class="stat">
                                    <i class="bi bi-collection"></i>
                                    <span>Multiple modules</span>
                                </div>
                            </div>
                            
                            <div class="course-footer">
                                <div class="course-price">
                                    <span class="price">${priceDisplay}</span>
                                </div>
                                
                                <a href="/Course/Details?id=${id}" class="btn btn-primary">
                                    <i class="bi bi-plus"></i> Enroll Now
                                </a>
                            </div>
                        </div>
                    </div>
                `;
                
                gridRow.prepend(col);
                
                // Add summary if it doesn't exist
                if (!container.querySelector('.results-summary')) {
                    const summary = document.createElement('div');
                    summary.className = 'results-summary mt-4';
                    summary.innerHTML = '<p>Showing <strong><span class="summary-count">1</span></strong> courses</p>';
                    container.appendChild(summary);
                }
            };
        });
        
        window.clearAllFilters = function() {
            const searchInput = document.getElementById('searchInput');
            const categoryFilter = document.getElementById('categoryFilter');
            if (searchInput) searchInput.value = '';
            if (categoryFilter) {
                categoryFilter.value = '';
                categoryFilter.dispatchEvent(new Event('change'));
            }
        };
    </script>
}
