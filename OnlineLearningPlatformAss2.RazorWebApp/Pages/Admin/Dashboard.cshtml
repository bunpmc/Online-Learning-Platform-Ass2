@page
@model OnlineLearningPlatformAss2.RazorWebApp.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<form id="aiForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid py-4 admin-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1 text-dark">System Overview</h2>
            <p class="text-muted mb-0">Real-time performance and revenue tracking.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="/Admin/CourseModeration" class="btn btn-white border shadow-sm rounded-3 px-3">
                <i class="bi bi-shield-check text-warning me-2"></i>Moderation
                @if (Model.Stats.PendingCourses > 0)
                {
                    <span class="badge bg-danger ms-1">@Model.Stats.PendingCourses</span>
                }
            </a>
            <div class="dropdown">
                <button class="btn btn-white border shadow-sm rounded-3 dropdown-toggle px-3" data-bs-toggle="dropdown">
                    <i class="bi bi-grid-fill text-primary me-2"></i>Quick Access
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2 rounded-3">
                    <li><a class="dropdown-item rounded-2" asp-page="/Admin/CourseManagement"><i class="bi bi-collection-play me-2"></i>Courses</a></li>
                    <li><a class="dropdown-item rounded-2" asp-page="/Admin/UserManagement"><i class="bi bi-people me-2"></i>Users</a></li>
                    <li><a class="dropdown-item rounded-2" asp-page="/Admin/LiveChat"><i class="bi bi-headset me-2"></i>Live Chat</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card admin-card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4">
                            <i class="bi bi-cash-stack text-primary fs-4"></i>
                        </div>
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">Net Profit</span>
                    </div>
                    <h2 class="admin-stat-value mb-1">@Model.Stats.TotalNetProfit.ToString("N0") ₫</h2>
                    <p class="text-muted small mb-0">30% platform commission</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="bg-success bg-opacity-10 p-3 rounded-4">
                            <i class="bi bi-currency-dollar text-success fs-4"></i>
                        </div>
                        <span class="text-success small fw-bold"><i class="bi bi-arrow-up-right"></i> +12%</span>
                    </div>
                    <h2 class="admin-stat-value mb-1">@Model.Stats.TotalRevenue.ToString("N0") ₫</h2>
                    <p class="text-muted small mb-0">Total Gross Revenue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="bg-info bg-opacity-10 p-3 rounded-4">
                            <i class="bi bi-people text-info fs-4"></i>
                        </div>
                        <span class="text-info small fw-bold">Students</span>
                    </div>
                    <h2 class="admin-stat-value mb-1">@Model.Stats.TotalUsers</h2>
                    <p class="text-muted small mb-0">@Model.Stats.TotalInstructors active instructors</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-4">
                            <i class="bi bi-book text-warning fs-4"></i>
                        </div>
                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Active</span>
                    </div>
                    <h2 class="admin-stat-value mb-1">@Model.Stats.TotalCourses</h2>
                    <p class="text-muted small mb-0">Across all categories</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-5">
        <div class="col-lg-7">
            <div class="card admin-card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-dark">Enrollment Trends</h6>
                    <div class="btn-group btn-group-sm rounded-pill overflow-hidden border p-1 bg-light">
                        <button class="btn btn-white border-0 rounded-pill px-3" onclick="filterChart('enroll', 3)">3M</button>
                        <button class="btn btn-white border-0 rounded-pill px-3" onclick="filterChart('enroll', 6)">6M</button>
                        <button class="btn btn-primary border-0 rounded-pill px-3 active" onclick="filterChart('enroll', 12)">12M</button>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="enrollmentChart" height="320"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card admin-card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-dark">Revenue Insights</h6>
                    <div class="d-flex gap-2 align-items-center">
                        <button onclick="toggleAiPanel()" class="btn btn-purple-subtle btn-sm rounded-circle d-flex align-items-center justify-content-center p-2 ai-insight-badge" title="AI Insight" style="width: 32px; height: 32px; background: rgba(124, 58, 237, 0.1); color: #7c3aed; border: none;">
                            <i class="bi bi-stars"></i>
                        </button>
                        <div class="btn-group btn-group-sm rounded-pill overflow-hidden border p-1 bg-light">
                            <button class="btn btn-white border-0 rounded-pill px-2" onclick="filterChart('revenue', 6)">6M</button>
                            <button class="btn btn-success border-0 rounded-pill px-2 active" onclick="filterChart('revenue', 12)">1Y</button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="320"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Floating AI Panel -->
    <div id="aiFloatingPanel" class="ai-floating-panel">
        <button class="ai-toggle-btn" onclick="toggleAiPanel()">
            <i class="bi bi-robot fs-4"></i>
        </button>
        <div class="ai-panel-header">
            <h6 class="fw-bold mb-0"><i class="bi bi-stars text-purple me-2"></i>AI Admin Assistant</h6>
            <button class="btn-close btn-sm" onclick="toggleAiPanel()"></button>
        </div>
        <div class="ai-panel-body" id="aiAnalysisBody">
            <div id="aiEmpty" class="text-center py-5">
                <div class="bg-light p-4 rounded-circle d-inline-block mb-3">
                    <i class="bi bi-chat-dots text-muted fs-1"></i>
                </div>
                <h5>Admin Intelligence</h5>
                <p class="text-muted small px-4">Ask me anything about your platform's revenue, students, or trends.</p>
                <div class="d-grid gap-2 px-4">
                    <button class="btn btn-primary rounded-pill shadow-sm" onclick="generateAiAnalysis()">
                        <i class="bi bi-graph-up me-1"></i>Analyze Revenue
                    </button>
                </div>
            </div>
            <div id="aiLoading" class="text-center py-4" style="display: none;">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="text-muted mt-2 small">AI is processing...</p>
            </div>
            <div id="aiResult" class="ai-analysis-content"></div>
        </div>
        <div class="ai-panel-footer">
            <div class="input-group input-group-sm">
                <input type="text" id="aiAdminInput" class="form-control rounded-start-pill border-end-0 ps-3" placeholder="Ask a question..." onkeypress="if(event.key === 'Enter') askAiQuestion()">
                <button class="btn btn-primary rounded-end-pill px-3" type="button" onclick="askAiQuestion()" id="btnSendAi">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <span class="x-small text-muted">Powered by Groq AI</span>
                <button onclick="clearAiChat()" class="btn btn-link btn-sm x-small text-decoration-none">Clear</button>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="row g-4">
        <div class="col-lg-12">
            <div class="card admin-card shadow-sm border-0">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Recent Transactions</h6>
                    <button class="btn btn-sm btn-white border rounded-pill px-3">View All</button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Student</th>
                                    <th>Item</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th class="text-end pe-4">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Stats.RecentOrders)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 38px; height: 38px; background: #eef2ff; color: #4361ee;">
                                                    <span class="small fw-bold">@order.Username[0].ToString().ToUpper()</span>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@order.Username</div>
                                                    <div class="text-muted x-small">ID: @order.OrderId.ToString().Substring(0,8)</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-dark fw-medium">@order.ItemTitle</div>
                                        </td>
                                        <td class="fw-bold">@order.Amount.ToString("N0") ₫</td>
                                        <td class="text-muted small">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="text-end pe-4">
                                            <span class="badge bg-success-subtle text-success border border-success border-opacity-10 rounded-pill px-3 py-2">Success</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        background-color: #fff;
    }
    .ai-analysis-content {
        font-size: 0.95rem;
        line-height: 1.8;
        color: #333;
    }
    .ai-analysis-content h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 1.2rem;
        margin-bottom: 0.5rem;
        color: #1a1a2e;
    }
    .ai-analysis-content ul {
        padding-left: 1.5rem;
    }
    .ai-analysis-content li {
        margin-bottom: 0.3rem;
    }
    .x-small { font-size: 0.75rem; }
    .bg-purple-subtle { background-color: #f5f3ff; }
    .text-purple { color: #7c3aed; }

    /* Floating AI Panel Styles */
    .ai-floating-panel {
        position: fixed;
        right: -350px; /* Hidden by default */
        top: 50%;
        transform: translateY(-50%);
        width: 350px;
        background-color: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        transition: right 0.3s ease-in-out;
        z-index: 1050;
        display: flex;
        flex-direction: column;
        max-height: 90vh;
    }
    .ai-floating-panel.active {
        right: 20px; /* Visible */
    }
    .ai-toggle-btn {
        position: absolute;
        left: -50px;
        top: 50%;
        transform: translateY(-50%);
        background-color: #7c3aed;
        color: #fff;
        border: none;
        border-radius: 8px 0 0 8px;
        padding: 10px 12px;
        cursor: pointer;
        box-shadow: -3px 0 8px rgba(0,0,0,0.1);
        transition: background-color 0.2s ease;
    }
    .ai-toggle-btn:hover {
        background-color: #6d28d9;
    }
    .ai-panel-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .ai-panel-body {
        padding: 1.5rem;
        flex-grow: 1;
        overflow-y: auto;
    }
    .ai-panel-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #eee;
        background-color: #f8f9fa;
        border-radius: 0 0 12px 12px;
    }
    .ai-insight-badge {
        cursor: pointer;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var allChartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.MonthlyChartData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            var allLabels = allChartData.map(d => d.month);
            var allEnrollments = allChartData.map(d => d.enrollmentCount);
            var allRevenues = allChartData.map(d => d.revenue);

            var enrollChart, revenueChart;

            // Line Chart - Enrollments
            var enrollCtx = document.getElementById('enrollmentChart').getContext('2d');
            var enrollGradient = enrollCtx.createLinearGradient(0, 0, 0, 320);
            enrollGradient.addColorStop(0, 'rgba(67, 97, 238, 0.2)');
            enrollGradient.addColorStop(1, 'rgba(67, 97, 238, 0)');

            enrollChart = new Chart(enrollCtx, {
                type: 'line',
                data: {
                    labels: allLabels,
                    datasets: [{
                        label: 'Enrollments',
                        data: allEnrollments,
                        borderColor: '#4361ee',
                        backgroundColor: enrollGradient,
                        borderWidth: 4,
                        fill: true,
                        tension: 0.45,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointBackgroundColor: '#4361ee',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { intersect: false, mode: 'index' },
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#f1f5f9', drawBorder: false },
                            ticks: { font: { family: 'Inter', size: 11 } }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { font: { family: 'Inter', size: 11 } }
                        }
                    }
                }
            });

            // Bar Chart - Revenue
            var revCtx = document.getElementById('revenueChart').getContext('2d');
            var revGradient = revCtx.createLinearGradient(0, 0, 0, 320);
            revGradient.addColorStop(0, '#2ec486');
            revGradient.addColorStop(1, '#a7f3d0');

            revenueChart = new Chart(revCtx, {
                type: 'bar',
                data: {
                    labels: allLabels,
                    datasets: [{
                        label: 'Revenue',
                        data: allRevenues,
                        backgroundColor: revGradient,
                        borderRadius: 12,
                        barThickness: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#f1f5f9', drawBorder: false },
                            ticks: {
                                callback: v => (v >= 1000000 ? v/1000000 + 'M' : v/1000 + 'K'),
                                font: { size: 10 }
                            }
                        },
                        x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                    }
                }
            });

            window.filterChart = function(type, months) {
                const labels = allLabels.slice(-months);
                if (type === 'enroll') {
                    enrollChart.data.labels = labels;
                    enrollChart.data.datasets[0].data = allEnrollments.slice(-months);
                    enrollChart.update();
                } else {
                    revenueChart.data.labels = labels;
                    revenueChart.data.datasets[0].data = allRevenues.slice(-months);
                    revenueChart.update();
                }
                const group = event.target.closest('.btn-group');
                group.querySelectorAll('.btn').forEach(b => b.classList.remove('btn-primary', 'btn-success', 'active'));
                event.target.classList.add(type === 'enroll' ? 'btn-primary' : 'btn-success', 'active');
            };

            window.toggleAiPanel = function() {
                const panel = document.getElementById('aiFloatingPanel');
                panel.classList.toggle('active');
            };

            window.generateAiAnalysis = async function () {
                const empty = document.getElementById('aiEmpty');
                const loading = document.getElementById('aiLoading');
                const result = document.getElementById('aiResult');

                if(empty) empty.style.display = 'none';
                loading.style.display = 'block';
                result.innerHTML = '';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const resp = await fetch('/Admin/Dashboard?handler=GenerateAiAnalysis', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }
                    });
                    const data = await resp.json();
                    result.innerHTML = `<h6><i class="bi bi-graph-up me-2"></i>Revenue Analysis</h6>` + simpleMarkdownToHtml(data.analysis);
                } catch (e) {
                    result.innerHTML = `<div class="alert alert-danger font-monospace small">${e.message}</div>`;
                } finally {
                    loading.style.display = 'none';
                    result.scrollTop = 0;
                }
            };

            window.askAiQuestion = async function() {
                const input = document.getElementById('aiAdminInput');
                const q = input.value.trim();
                if(!q) return;

                const empty = document.getElementById('aiEmpty');
                const loading = document.getElementById('aiLoading');
                const result = document.getElementById('aiResult');
                const btn = document.getElementById('btnSendAi');

                if(empty) empty.style.display = 'none';
                loading.style.display = 'block';
                input.value = '';
                btn.disabled = true;

                // Append question
                const qHtml = `<div class="mb-3 p-2 bg-light rounded-3 small border-start border-primary border-4 shadow-sm">
                                <strong>You:</strong><br>${q}
                               </div>`;
                result.innerHTML += qHtml;
                result.scrollTop = result.scrollHeight;

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const resp = await fetch('/Admin/Dashboard?handler=AskAdmin', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ question: q })
                    });
                    const data = await resp.json();
                    const aHtml = `<div class="mb-4 small"><strong>AI:</strong><br>${simpleMarkdownToHtml(data.answer)}</div>`;
                    result.innerHTML += aHtml;
                } catch (e) {
                    result.innerHTML += `<div class="alert alert-danger font-monospace small">${e.message}</div>`;
                } finally {
                    loading.style.display = 'none';
                    btn.disabled = false;
                    result.scrollTop = result.scrollHeight;
                }
            };

            window.clearAiChat = function() {
                document.getElementById('aiResult').innerHTML = '';
                document.getElementById('aiEmpty').style.display = 'block';
            };

            function simpleMarkdownToHtml(md) {
                if (!md) return '';
                return md
                    .replace(/### (.*)/g, '<h6 class="fw-bold mt-3">$1</h6>')
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/^- (.*)/gm, '<li>$1</li>')
                    .replace(/\n/g, '<br>');
            }
        });
    </script>
}
