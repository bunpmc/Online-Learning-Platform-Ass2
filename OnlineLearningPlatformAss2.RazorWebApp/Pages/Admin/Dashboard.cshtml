@page
@model OnlineLearningPlatformAss2.RazorWebApp.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<form id="aiForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid py-4 admin-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">System Overview</h2>
            <p class="text-muted">Monitor your platform's health and growth.</p>
        </div>
        <div class="btn-group">
            <a asp-page="/Admin/CourseModeration" class="btn btn-outline-primary shadow-sm">
                <i class="bi bi-shield-check me-2"></i>Moderation
                @if (Model.Stats.PendingCourses > 0)
                {
                    <span class="badge bg-danger ms-2">@Model.Stats.PendingCourses</span>
                }
            </a>
            <a asp-page="/Admin/CourseManagement" class="btn btn-outline-info shadow-sm">
                <i class="bi bi-collection-play me-2"></i>Courses
            </a>
            <a asp-page="/Admin/UserManagement" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-people me-2"></i>User Management
            </a>
            <a asp-page="/Admin/LiveChat" class="btn btn-outline-success shadow-sm">
                <i class="bi bi-headset me-2"></i>Live Chat
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card admin-card p-4 h-100 shadow-sm border-0 bg-primary text-white">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-white bg-opacity-20 p-3 rounded-3 me-3">
                        <i class="bi bi-wallet2 fs-3 text-white"></i>
                    </div>
                    <span class="card-title-admin text-white opacity-75">Net Profit (30%)</span>
                </div>
                <h2 class="admin-stat-value mb-0 text-white">@Model.Stats.TotalNetProfit.ToString("N0") ₫</h2>
                <p class="small mb-0 mt-2 opacity-75">Platform commission</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card p-4 h-100 shadow-sm border-start border-primary border-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-currency-dollar text-primary fs-3"></i>
                    </div>
                    <span class="card-title-admin">Gross Revenue</span>
                </div>
                <h2 class="admin-stat-value mb-0">@Model.Stats.TotalRevenue.ToString("N0") ₫</h2>
                <p class="text-success fw-bold small mb-0 mt-2"><i class="bi bi-arrow-up-right me-1"></i>+12.5%</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card p-4 h-100 shadow-sm">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-people text-success fs-3"></i>
                    </div>
                    <span class="card-title-admin">Total Students</span>
                </div>
                <h2 class="admin-stat-value mb-0">@Model.Stats.TotalUsers</h2>
                <p class="text-muted small mb-0 mt-2">@Model.Stats.TotalInstructors Instructors</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card p-4 h-100 shadow-sm">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-info bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-book text-info fs-3"></i>
                    </div>
                    <span class="card-title-admin">Active Courses</span>
                </div>
                <h2 class="admin-stat-value mb-0">@Model.Stats.TotalCourses</h2>
                <p class="text-muted small mb-0 mt-2">@Model.Stats.TotalEnrollments Enrollments</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card admin-card p-4 h-100 shadow-sm">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-hourglass-split text-warning fs-3"></i>
                    </div>
                    <span class="card-title-admin">Pending Reviews</span>
                </div>
                <h2 class="admin-stat-value mb-0 text-warning">@Model.Stats.PendingCourses</h2>
                <p class="text-muted small mb-0 mt-2">Needs moderation</p>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-graph-up text-primary me-2"></i>Student Enrollments</h5>
                    <div class="btn-group btn-group-sm" id="enrollFilterGroup">
                        <button class="btn btn-outline-primary" onclick="filterChart('enroll', 3)">3M</button>
                        <button class="btn btn-outline-primary" onclick="filterChart('enroll', 6)">6M</button>
                        <button class="btn btn-outline-primary active" onclick="filterChart('enroll', 12)">12M</button>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="enrollmentChart" height="280"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-bar-chart-fill text-success me-2"></i>Revenue</h5>
                    <div class="btn-group btn-group-sm" id="revenueFilterGroup">
                        <button class="btn btn-outline-success" onclick="filterChart('revenue', 3)">3M</button>
                        <button class="btn btn-outline-success" onclick="filterChart('revenue', 6)">6M</button>
                        <button class="btn btn-outline-success active" onclick="filterChart('revenue', 12)">12M</button>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="280"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- AI Revenue Analysis -->
    <div class="row g-4 mb-5">
        <div class="col-12">
            <div class="card admin-card shadow-sm">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-robot text-purple me-2" style="color: #7c3aed;"></i>AI Revenue Analysis</h5>
                    <button id="btnAiAnalysis" class="btn btn-outline-primary btn-sm rounded-pill px-4" onclick="generateAiAnalysis()">
                        <i class="bi bi-stars me-1"></i>Generate Analysis
                    </button>
                </div>
                <div class="card-body" id="aiAnalysisBody" style="display: none;">
                    <div id="aiLoading" class="text-center py-5" style="display: none;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="text-muted mt-3">AI is analyzing your data...</p>
                    </div>
                    <div id="aiResult" class="ai-analysis-content"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Orders -->
        <div class="col-lg-8">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header bg-white py-4 border-0">
                    <h5 class="fw-bold mb-0">Recent Transactions</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Student</th>
                                    <th>Item</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th class="text-end pe-4">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Stats.RecentOrders)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-secondary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                                    <span class="small fw-bold text-secondary">@order.Username[0].ToString().ToUpper()</span>
                                                </div>
                                                <span class="fw-bold">@order.Username</span>
                                            </div>
                                        </td>
                                        <td>@order.ItemTitle</td>
                                        <td class="fw-bold text-dark">@order.Amount.ToString("N0") ₫</td>
                                        <td class="text-muted small">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="text-end pe-4">
                                            <span class="badge badge-admin badge-active rounded-pill">COMPLETED</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Quick Actions -->
        <div class="col-lg-4">
            <div class="card admin-card shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Quick Actions</h5>
                    <div class="d-grid gap-3">
                        <button class="btn btn-light text-start py-3 px-4 border shadow-sm rounded-3 hover-lift">
                            <i class="bi bi-file-earmark-spreadsheet me-3 text-success fs-5"></i>Export Sales Report
                        </button>
                        <button class="btn btn-light text-start py-3 px-4 border shadow-sm rounded-3 hover-lift">
                            <i class="bi bi-envelope me-3 text-primary fs-5"></i>Broadcast Message
                        </button>
                        <button class="btn btn-light text-start py-3 px-4 border shadow-sm rounded-3 hover-lift">
                            <i class="bi bi-gear me-3 text-secondary fs-5"></i>System Settings
                        </button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-lg bg-primary text-white p-4 overflow-hidden position-relative">
                <div class="position-relative" style="z-index: 2;">
                    <h5 class="fw-bold">Need Help?</h5>
                    <p class="small opacity-75 mb-4">Check out our documentation for advanced system configurations.</p>
                    <a href="#" class="btn btn-light btn-sm rounded-pill px-4 fw-bold">Read Docs</a>
                </div>
                <i class="bi bi-shield-lock position-absolute bottom-0 end-0 display-1 opacity-10 mb-n3 me-n3"></i>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        background-color: #fff;
    }
    .ai-analysis-content {
        font-size: 0.95rem;
        line-height: 1.8;
        color: #333;
    }
    .ai-analysis-content h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 1.2rem;
        margin-bottom: 0.5rem;
        color: #1a1a2e;
    }
    .ai-analysis-content ul {
        padding-left: 1.5rem;
    }
    .ai-analysis-content li {
        margin-bottom: 0.3rem;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var allChartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.MonthlyChartData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            var allLabels = allChartData.map(d => d.month);
            var allEnrollments = allChartData.map(d => d.enrollmentCount);
            var allRevenues = allChartData.map(d => d.revenue);

            // Default: show last 12 months
            var labels = allLabels;
            var enrollments = allEnrollments;
            var revenues = allRevenues;

            var enrollChart, revenueChart;

            // Line Chart - Enrollments
            var enrollCtx = document.getElementById('enrollmentChart').getContext('2d');
            var enrollGradient = enrollCtx.createLinearGradient(0, 0, 0, 280);
            enrollGradient.addColorStop(0, 'rgba(67, 97, 238, 0.3)');
            enrollGradient.addColorStop(1, 'rgba(67, 97, 238, 0.02)');

            enrollChart = new Chart(enrollCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Students Enrolled',
                        data: enrollments,
                        borderColor: '#4361ee',
                        backgroundColor: enrollGradient,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#4361ee',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            titleFont: { size: 13 },
                            bodyFont: { size: 13 },
                            padding: 12,
                            cornerRadius: 8
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0, font: { size: 12 } },
                            grid: { color: 'rgba(0,0,0,0.05)' }
                        },
                        x: {
                            ticks: { font: { size: 11 }, maxRotation: 45 },
                            grid: { display: false }
                        }
                    },
                    animation: { duration: 1200, easing: 'easeOutQuart' }
                }
            });

            // Bar Chart - Revenue
            var revCtx = document.getElementById('revenueChart').getContext('2d');
            var revGradient = revCtx.createLinearGradient(0, 0, 0, 280);
            revGradient.addColorStop(0, 'rgba(46, 196, 134, 0.85)');
            revGradient.addColorStop(1, 'rgba(46, 196, 134, 0.25)');

            revenueChart = new Chart(revCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue (₫)',
                        data: revenues,
                        backgroundColor: revGradient,
                        borderColor: '#2ec486',
                        borderWidth: 2,
                        borderRadius: 6,
                        borderSkipped: false,
                        hoverBackgroundColor: '#2ec486'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            titleFont: { size: 13 },
                            bodyFont: { size: 13 },
                            padding: 12,
                            cornerRadius: 8,
                            callbacks: {
                                label: function (ctx) {
                                    return ctx.parsed.y.toLocaleString('vi-VN') + ' ₫';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { size: 12 },
                                callback: function (v) {
                                    if (v >= 1000000) return (v / 1000000).toFixed(1) + 'M';
                                    if (v >= 1000) return (v / 1000).toFixed(0) + 'K';
                                    return v;
                                }
                            },
                            grid: { color: 'rgba(0,0,0,0.05)' }
                        },
                        x: {
                            ticks: { font: { size: 11 }, maxRotation: 45 },
                            grid: { display: false }
                        }
                    },
                    animation: { duration: 1200, easing: 'easeOutQuart' }
                }
            });
            // Filter function - accessible globally
            window.filterChart = function(chartType, months) {
                var slicedLabels = allLabels.slice(-months);
                var group;
                
                if (chartType === 'enroll') {
                    var slicedData = allEnrollments.slice(-months);
                    enrollChart.data.labels = slicedLabels;
                    enrollChart.data.datasets[0].data = slicedData;
                    enrollChart.update('normal');
                    group = document.getElementById('enrollFilterGroup');
                } else {
                    var slicedData = allRevenues.slice(-months);
                    revenueChart.data.labels = slicedLabels;
                    revenueChart.data.datasets[0].data = slicedData;
                    revenueChart.update('normal');
                    group = document.getElementById('revenueFilterGroup');
                }
                
                // Toggle active state
                group.querySelectorAll('.btn').forEach(b => b.classList.remove('active'));
                event.target.classList.add('active');
            };
        });

        // AI Analysis
        window.generateAiAnalysis = async function () {
            var body = document.getElementById('aiAnalysisBody');
            var loading = document.getElementById('aiLoading');
            var result = document.getElementById('aiResult');
            var btn = document.getElementById('btnAiAnalysis');

            body.style.display = 'block';
            loading.style.display = 'block';
            result.innerHTML = '';
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Analyzing...';

            try {
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var resp = await fetch('/Admin/Dashboard?handler=GenerateAiAnalysis', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    }
                });
                var data = await resp.json();
                result.innerHTML = simpleMarkdownToHtml(data.analysis);
            } catch (e) {
                result.innerHTML = '<div class="alert alert-danger">Error: ' + e.message + '</div>';
            } finally {
                loading.style.display = 'none';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-stars me-1"></i>Regenerate';
            }
        };

        function simpleMarkdownToHtml(md) {
            if (!md) return '';
            var html = md
                .replace(/### (.*)/g, '<h3>$1</h3>')
                .replace(/## (.*)/g, '<h3>$1</h3>')
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/^- (.*)/gm, '<li>$1</li>')
                .replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>')
                .replace(/\n/g, '<br>');
            // Fix multiple consecutive <ul> tags
            html = html.replace(/<\/ul><br><ul>/g, '');
            html = html.replace(/<br><li>/g, '<li>');
            html = html.replace(/<\/li><br>/g, '</li>');
            // Wrap orphaned <li> in <ul>
            html = html.replace(/(?<!<ul>)(<li>)/g, '<ul>$1');
            html = html.replace(/(<\/li>)(?!<\/ul>|<li>)/g, '$1</ul>');
            return html;
        }
    </script>
}
