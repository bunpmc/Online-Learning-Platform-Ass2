@page
@model OnlineLearningPlatformAss2.RazorWebApp.Pages.Admin.CourseManagementModel
@{
    ViewData["Title"] = "Course Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="container py-5 admin-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Course Management</h2>
            <p class="text-muted">Monitor and manage all courses on the platform.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#courseModal" onclick="openCreateModal()">
                <i class="bi bi-plus-circle me-2"></i>Create Course
            </button>
            <a asp-page="/Admin/Dashboard" class="btn btn-link text-decoration-none">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card admin-card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0" id="courseTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Course</th>
                            <th>Instructor</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Students</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="courseTableBody">
                        @foreach (var course in Model.Courses)
                        {
                            <tr id="row-@course.Id" data-id="@course.Id">
                                <td class="ps-4">
                                    <div class="fw-bold">@course.Title</div>
                                    <div class="text-muted small">@course.CategoryName</div>
                                </td>
                                <td>@course.InstructorName</td>
                                <td class="fw-bold">@course.FormattedPrice</td>
                                <td>
                                    @if (course.Status == "Published") { <span class="badge bg-success bg-opacity-10 text-success">PUBLISHED</span> }
                                    else if (course.Status == "Suspended") { <span class="badge bg-dark">SUSPENDED</span> }
                                    else if (course.Status == "Pending") { <span class="badge bg-warning bg-opacity-10 text-warning">PENDING</span> }
                                    else { <span class="badge bg-secondary">@course.Status.ToUpper()</span> }
                                </td>
                                <td>@course.StudentCount</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="Edit" onclick="openEditModal('@course.Id', '@course.Title.Replace("'", "\\'")','@(course.Description?.Replace("'", "\\'").Replace("\n","\\n").Replace("\r","") ?? "")','@course.Price','@course.ImageUrl','@course.Language','@course.Status')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (course.Status == "Published")
                                        {
                                            <button class="btn btn-outline-warning" title="Suspend" onclick="suspendCourse('@course.Id')">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        }
                                        else if (course.Status == "Suspended")
                                        {
                                            <button class="btn btn-outline-success" title="Unsuspend" onclick="unsuspendCourse('@course.Id')">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        }
                                        <button class="btn btn-outline-danger" title="Delete" onclick="deleteCourse('@course.Id', '@course.Title.Replace("'", "\\'")') ">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Course Modal -->
<div class="modal fade" id="courseModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="courseModalTitle">Create Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editCourseId" />
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Title</label>
                        <input type="text" class="form-control" id="courseTitle" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Price (₫)</label>
                        <input type="number" class="form-control" id="coursePrice" min="0" value="0" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Description</label>
                        <textarea class="form-control" id="courseDescription" rows="3"></textarea>
                    </div>
                    <div class="col-md-6" id="categoryField">
                        <label class="form-label fw-bold">Category</label>
                        <select class="form-select" id="courseCategory">
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6" id="instructorField">
                        <label class="form-label fw-bold">Instructor</label>
                        <select class="form-select" id="courseInstructor">
                            @foreach (var ins in Model.Instructors)
                            {
                                <option value="@ins.Id">@ins.Username</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Level</label>
                        <select class="form-select" id="courseLevel">
                            <option value="Beginner">Beginner</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Advanced">Advanced</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Language</label>
                        <select class="form-select" id="courseLanguage">
                            <option value="English">English</option>
                            <option value="Vietnamese">Vietnamese</option>
                        </select>
                    </div>
                    <div class="col-md-4" id="statusField" style="display:none;">
                        <label class="form-label fw-bold">Status</label>
                        <select class="form-select" id="courseStatus">
                            <option value="Published">Published</option>
                            <option value="Pending">Pending</option>
                            <option value="Suspended">Suspended</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold">Image URL</label>
                        <input type="url" class="form-control" id="courseImageUrl" placeholder="https://..." />
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="btnSaveCourse" onclick="saveCourse()">
                    <i class="bi bi-check-circle me-1"></i>Save Course
                </button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    var isEditMode = false;

    function getToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]').value;
    }

    function openCreateModal() {
        isEditMode = false;
        document.getElementById('courseModalTitle').textContent = 'Create Course';
        document.getElementById('editCourseId').value = '';
        document.getElementById('courseTitle').value = '';
        document.getElementById('courseDescription').value = '';
        document.getElementById('coursePrice').value = '0';
        document.getElementById('courseImageUrl').value = '';
        document.getElementById('courseLevel').value = 'Beginner';
        document.getElementById('courseLanguage').value = 'English';
        document.getElementById('instructorField').style.display = '';
        document.getElementById('statusField').style.display = 'none';
    }

    function openEditModal(id, title, desc, price, imageUrl, language, status) {
        isEditMode = true;
        document.getElementById('courseModalTitle').textContent = 'Edit Course';
        document.getElementById('editCourseId').value = id;
        document.getElementById('courseTitle').value = title;
        document.getElementById('courseDescription').value = desc;
        document.getElementById('coursePrice').value = price;
        document.getElementById('courseImageUrl').value = imageUrl || '';
        document.getElementById('courseLanguage').value = language || 'English';
        document.getElementById('courseStatus').value = status;
        document.getElementById('instructorField').style.display = 'none';
        document.getElementById('statusField').style.display = '';
        var modal = new bootstrap.Modal(document.getElementById('courseModal'));
        modal.show();
    }

    async function saveCourse() {
        var btn = document.getElementById('btnSaveCourse');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

        try {
            var url, body;
            if (isEditMode) {
                url = '?handler=Update';
                body = {
                    courseId: document.getElementById('editCourseId').value,
                    title: document.getElementById('courseTitle').value,
                    description: document.getElementById('courseDescription').value,
                    price: parseFloat(document.getElementById('coursePrice').value),
                    categoryId: document.getElementById('courseCategory').value,
                    imageUrl: document.getElementById('courseImageUrl').value || null,
                    level: document.getElementById('courseLevel').value,
                    language: document.getElementById('courseLanguage').value,
                    status: document.getElementById('courseStatus').value
                };
            } else {
                url = '?handler=Create';
                body = {
                    title: document.getElementById('courseTitle').value,
                    description: document.getElementById('courseDescription').value,
                    price: parseFloat(document.getElementById('coursePrice').value),
                    categoryId: document.getElementById('courseCategory').value,
                    instructorId: document.getElementById('courseInstructor').value,
                    imageUrl: document.getElementById('courseImageUrl').value || null,
                    level: document.getElementById('courseLevel').value,
                    language: document.getElementById('courseLanguage').value
                };
            }

            var resp = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify(body)
            });
            var data = await resp.json();
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('courseModal')).hide();
                // SignalR will handle the real-time DOM update
            } else {
                alert('Failed to save course.');
            }
        } catch (e) {
            alert('Error: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Save Course';
        }
    }

    async function suspendCourse(id) {
        if(!confirm('Suspend this course? It will no longer be visible to students.')) return;
        const response = await fetch(`?handler=Suspend&id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        if (response.ok) location.reload();
    }

    async function unsuspendCourse(id) {
        if(!confirm('Restore this course to Published status?')) return;
        const response = await fetch(`?handler=Unsuspend&id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        if (response.ok) location.reload();
    }

    async function deleteCourse(id, title) {
        if(!confirm(`Delete course "${title}"? This action cannot be undone.`)) return;
        const response = await fetch(`?handler=Delete&id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': getToken() }
        });
        var data = await response.json();
        if (data.success) {
            var row = document.getElementById('row-' + id);
            if (row) row.style.transition = 'opacity 0.3s', row.style.opacity = '0';
            setTimeout(() => { if (row) row.remove(); }, 300);
        } else {
            alert('Cannot delete this course. It may have enrollments or orders.');
        }
    }

    // ===== SignalR Real-time Updates =====
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/course")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveCourseUpdated", function (course) {
        var row = document.getElementById('row-' + course.id);
        if (row) {
            row.querySelector('td:nth-child(1) .fw-bold').textContent = course.title;
            row.querySelector('td:nth-child(1) .text-muted').textContent = course.categoryName;
            row.querySelector('td:nth-child(2)').textContent = course.instructorName;
            row.querySelector('td:nth-child(3)').textContent = course.price === 0 ? 'Miễn phí' : course.price.toLocaleString('vi-VN') + '₫';
            var statusTd = row.querySelector('td:nth-child(4)');
            if (course.status === 'Published') statusTd.innerHTML = '<span class="badge bg-success bg-opacity-10 text-success">PUBLISHED</span>';
            else if (course.status === 'Suspended') statusTd.innerHTML = '<span class="badge bg-dark">SUSPENDED</span>';
            else if (course.status === 'Pending') statusTd.innerHTML = '<span class="badge bg-warning bg-opacity-10 text-warning">PENDING</span>';
            else statusTd.innerHTML = '<span class="badge bg-secondary">' + course.status.toUpperCase() + '</span>';
            row.querySelector('td:nth-child(5)').textContent = course.studentCount || 0;

            // Update action buttons
            var actionTd = row.querySelector('td:nth-child(6) .btn-group');
            if (actionTd) {
                var id = course.id;
                actionTd.innerHTML = `
                    <button class="btn btn-outline-primary" title="Edit" onclick="openEditModal('${id}', '${(course.title||'').replace(/'/g,"\\'")}','${(course.description||'').replace(/'/g,"\\'")}','${course.price}','${course.imageUrl||''}','${course.language||'English'}','${course.status}')"><i class="bi bi-pencil"></i></button>
                    ${course.status === 'Published' ? `<button class="btn btn-outline-warning" title="Suspend" onclick="suspendCourse('${id}')"><i class="bi bi-pause-circle"></i></button>` : ''}
                    ${course.status === 'Suspended' ? `<button class="btn btn-outline-success" title="Unsuspend" onclick="unsuspendCourse('${id}')"><i class="bi bi-play-circle"></i></button>` : ''}
                    <button class="btn btn-outline-danger" title="Delete" onclick="deleteCourse('${id}', '${(course.title||'').replace(/'/g,"\\'")}')"><i class="bi bi-trash"></i></button>`;
            }

            // Flash animation
            row.style.transition = 'background-color 1s ease';
            row.style.backgroundColor = 'rgba(67, 97, 238, 0.1)';
            setTimeout(() => { row.style.backgroundColor = ''; }, 2000);
        }
    });

    connection.on("ReceiveCourseAdded", function (course) {
        var tbody = document.getElementById('courseTableBody');
        if (!tbody) return;
        var id = course.id;
        var price = course.price === 0 ? 'Miễn phí' : course.price.toLocaleString('vi-VN') + '₫';
        var statusBadge = '';
        if (course.status === 'Published') statusBadge = '<span class="badge bg-success bg-opacity-10 text-success">PUBLISHED</span>';
        else if (course.status === 'Suspended') statusBadge = '<span class="badge bg-dark">SUSPENDED</span>';
        else if (course.status === 'Pending') statusBadge = '<span class="badge bg-warning bg-opacity-10 text-warning">PENDING</span>';
        else statusBadge = '<span class="badge bg-secondary">' + course.status.toUpperCase() + '</span>';

        var tr = document.createElement('tr');
        tr.id = 'row-' + id;
        tr.setAttribute('data-id', id);
        tr.style.transition = 'background-color 1s ease';
        tr.style.backgroundColor = 'rgba(67, 97, 238, 0.1)';
        tr.innerHTML = `
            <td class="ps-4">
                <div class="fw-bold">${course.title}</div>
                <div class="text-muted small">${course.categoryName}</div>
            </td>
            <td>${course.instructorName}</td>
            <td class="fw-bold">${price}</td>
            <td>${statusBadge}</td>
            <td>${course.studentCount || 0}</td>
            <td class="text-end pe-4">
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary" title="Edit" onclick="openEditModal('${id}', '${(course.title||'').replace(/'/g,"\\'")}','${(course.description||'').replace(/'/g,"\\'")}','${course.price}','${course.imageUrl||''}','${course.language||'English'}','${course.status}')"><i class="bi bi-pencil"></i></button>
                    ${course.status === 'Published' ? `<button class="btn btn-outline-warning" title="Suspend" onclick="suspendCourse('${id}')"><i class="bi bi-pause-circle"></i></button>` : ''}
                    ${course.status === 'Suspended' ? `<button class="btn btn-outline-success" title="Unsuspend" onclick="unsuspendCourse('${id}')"><i class="bi bi-play-circle"></i></button>` : ''}
                    <button class="btn btn-outline-danger" title="Delete" onclick="deleteCourse('${id}', '${(course.title||'').replace(/'/g,"\\'")}')"><i class="bi bi-trash"></i></button>
                </div>
            </td>`;
        tbody.prepend(tr);
        setTimeout(() => { tr.style.backgroundColor = ''; }, 2000);
    });

    connection.on("ReceiveCourseDeleted", function (courseId) {
        var row = document.getElementById('row-' + courseId);
        if (row) {
            row.style.transition = 'opacity 0.3s';
            row.style.opacity = '0';
            setTimeout(() => row.remove(), 300);
        }
    });

    connection.start()
        .then(() => console.log("SignalR CourseHub connected on CourseManagement."))
        .catch(err => console.error("SignalR connection error:", err));
</script>
}
