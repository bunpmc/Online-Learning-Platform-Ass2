@page
@model OnlineLearningPlatformAss2.RazorWebApp.Pages.Admin.UserManagementModel
@{
    ViewData["Title"] = "User Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="container py-5 admin-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">User Management</h2>
            <p class="text-muted">Manage user roles and account statuses.</p>
        </div>
        <a asp-page="/Admin/Dashboard" class="btn btn-link text-decoration-none">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <div class="card admin-card shadow-sm">
        <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="admin-search-container position-relative flex-grow-1">
                <i class="bi bi-search admin-search-icon"></i>
                <input type="text" id="userSearchInput" class="form-control admin-search-input" 
                       placeholder="Search users by name or email..." value="@Model.SearchTerm">
            </div>
            <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="bi bi-person-plus me-2"></i>Add Internal User
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">User</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px;">
                                            <span class="fw-bold text-primary">@user.Username[0].ToString().ToUpper()</span>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">@user.Username</h6>
                                            <span class="text-muted small">ID: @user.Id.ToString().Substring(0, 8)</span>
                                        </div>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    <select class="form-select form-select-sm border-0 bg-light w-auto fw-bold" 
                                            onchange="changeRole('@user.Id', this.value)" @(user.Username == "admin" ? "disabled" : "")>
                                        <option value="User" selected="@(user.RoleName == "User")">Learner</option>
                                        <option value="Instructor" selected="@(user.RoleName == "Instructor")">Instructor</option>
                                        <option value="Admin" selected="@(user.RoleName == "Admin")">Admin</option>
                                    </select>
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge badge-admin badge-active rounded-pill">ACTIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-admin badge-suspended rounded-pill">SUSPENDED</span>
                                    }
                                </td>
                                <td class="text-muted small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-light border @(user.IsActive ? "text-danger" : "text-success") mx-1" 
                                                onclick="toggleStatus('@user.Id')" @(user.Username == "admin" ? "disabled" : "")
                                                title="@(user.IsActive ? "Suspend User" : "Activate User")">
                                            <i class="bi @(user.IsActive ? "bi-person-slash" : "bi-person-check")"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border text-primary mx-1" 
                                                onclick="resetPassword('@user.Id')" 
                                                title="Reset Password">
                                            <i class="bi bi-shield-lock"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border text-danger mx-1" 
                                                onclick="deleteUser('@user.Id')" @(user.Username == "admin" ? "disabled" : "")
                                                title="Delete User">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade admin-modal" id="addUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Add Internal User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addUserForm">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" name="email" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select" name="role" required>
                            <option value="User">Learner</option>
                            <option value="Instructor">Instructor</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" onclick="submitAddUser()">Create User</button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade admin-modal" id="resetPasswordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="resetPasswordForm">
                    <input type="hidden" id="resetUserId" name="userId">
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" id="newPassword" name="newPassword" required>
                        <div class="form-text">Choose a strong password for this user.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" onclick="submitResetPassword()">Reset Password</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    // SignalR Connection
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/admin")
        .withAutomaticReconnect()
        .build();

    connection.on("ReceiveUserAdded", (user) => {
        // Simple approach: reload or append. Append is better for "CRUD over SignalR"
        location.reload(); 
    });

    connection.on("ReceiveUserRoleChanged", (userId, newRole) => {
        const row = document.querySelector(`tr:has(span:contains("ID: ${userId.substring(0, 8)}"))`) || 
                    document.querySelector(`select[onchange*="${userId}"]`)?.closest('tr');
        if (row) {
            const select = row.querySelector('select');
            if (select) select.value = newRole;
            showToast(`User role updated to ${newRole}`, 'success');
        } else {
            location.reload();
        }
    });

    connection.on("ReceiveUserStatusToggled", (userId, isActive) => {
        location.reload(); // Complex to toggle all buttons and badges via JS, reload is safer for now but we can refine
    });

    connection.on("ReceiveUserDeleted", (userId) => {
        location.reload();
    });

    connection.on("ReceiveUserPasswordReset", (userId) => {
        showToast("Password has been reset successfully", 'success');
    });

    connection.start().catch(err => console.error(err.toString()));

    // Search Functionality
    const searchInput = document.getElementById('userSearchInput');
    let debounceTimer;
    
    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            const term = this.value.trim();
            window.location.href = `?SearchTerm=${encodeURIComponent(term)}`;
        }, 600);
    });

    async function toggleStatus(id) {
        if(!confirm('Are you sure you want to change this user\'s status?')) return;
        try {
            await connection.invoke("ToggleUserStatus", id);
        } catch (err) {
            console.error(err);
            alert("Error toggling status: " + err.message);
        }
    }

    async function changeRole(id, role) {
        if(!confirm(`Change user role to ${role}?`)) { location.reload(); return; }
        try {
            await connection.invoke("ChangeUserRole", id, role);
        } catch (err) {
            console.error(err);
            alert("Error changing role: " + err.message);
            location.reload();
        }
    }

    async function deleteUser(id) {
        if(!confirm('PERMANENT DELETE: Are you sure? This action cannot be undone.')) return;
        try {
            await connection.invoke("DeleteUser", id);
        } catch (err) {
            console.error(err);
            alert("Error deleting user: " + err.message);
        }
    }

    async function submitAddUser() {
        const form = document.getElementById('addUserForm');
        const formData = new FormData(form);
        const username = formData.get('username');
        const email = formData.get('email');
        const password = formData.get('password');
        const role = formData.get('role');
        
        try {
            await connection.invoke("AddUser", username, email, password, role);
            bootstrap.Modal.getInstance(document.getElementById('addUserModal')).hide();
            form.reset();
        } catch (err) {
            console.error(err);
            alert('Failed to add user: ' + err.message);
        }
    }

    function resetPassword(id) {
        document.getElementById('resetUserId').value = id;
        document.getElementById('newPassword').value = '';
        new bootstrap.Modal(document.getElementById('resetPasswordModal')).show();
    }

    async function submitResetPassword() {
        const userId = document.getElementById('resetUserId').value;
        const newPassword = document.getElementById('newPassword').value;
        
        if (!newPassword) {
            alert('Please enter a new password');
            return;
        }
        
        try {
            await connection.invoke("ResetUserPassword", userId, newPassword);
            bootstrap.Modal.getInstance(document.getElementById('resetPasswordModal')).hide();
            showToast("Password reset request sent", 'info');
        } catch (err) {
            console.error(err);
            alert('Failed to reset password: ' + err.message);
        }
    }

    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `alert alert-${type} position-fixed bottom-0 end-0 m-3 shadow-lg`;
        toast.style.zIndex = 10000;
        toast.innerHTML = `<i class="bi bi-info-circle-fill me-2"></i>${message}`;
        document.body.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
        }, 3000);
    }
</script>
}
